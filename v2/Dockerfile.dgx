# SurviveCity v2 — DGX training container.
#
# DEPENDENCY HISTORY (read this if you wonder why we chose this stack):
#
# We tried mirroring v1's Dockerfile.dgx (transformers 4.40.2 + peft 0.10.0 +
# trl 0.8.6 + Unsloth git head + torchao 0.7.0) and hit FOUR cascading
# dependency failures in sequence:
#
#   1. peft >=0.13 (pulled in by Unsloth) demands torchao >= 0.16.0 in
#      `is_torchao_available()`, but torch 2.5 can only have torchao <= 0.7.
#      → Fixed by uninstalling torchao entirely.
#   2. trl 0.15+ chain-imports `mergekit` from callbacks.py unconditionally.
#      → Fixed by `pip install mergekit`.
#   3. trl 0.15+ also chain-imports `llm_blender` from judges.py.
#      → Tried `pip install llm-blender`, but...
#   4. ...the latest `llm_blender` is built against an older transformers API
#      (`from transformers.utils.hub import TRANSFORMERS_CACHE` — that
#      constant was renamed to `HF_HUB_CACHE` in modern transformers).
#      `llm_blender` simply does not import in our env.
#
# The root cause: Unsloth's git head pulls bleeding-edge `transformers/peft/trl`,
# and `trl` 0.15+ has unconditional optional-integration imports that the
# rest of the ecosystem hasn't caught up with.
#
# DECISION: drop Unsloth, pin trl==0.15.2, install mergekit, and STUB OUT
# llm_blender as a tiny in-place package (instead of installing the real
# one from pypi).
#
# Why stub instead of install? llm_blender's runtime dep tree is huge
# (dataclasses_json, sentence-transformers, pytorch-lightning, ...) and
# they conflict with our pinned transformers/peft stack. But trl only
# does `import llm_blender` at module load — our GRPO code never
# instantiates a judge. So a 6-line stub package with a fake `Blender`
# class is sufficient to make `from trl import GRPOTrainer` succeed,
# without dragging in any of the real package's dependencies.
#
# We tried trl 0.13.0 first hoping to skip the mergekit/llm_blender
# chain, but trl 0.13's `from trl import GRPOTrainer` doesn't expose
# it at the top level — only via deeper module paths — so it doesn't
# actually work for our import chain. trl 0.15.2 is the first version
# where the top-level export is reliable.
#
# Insurance patches:
#   * transformers/utils/hub.py gets a TRANSFORMERS_CACHE alias appended
#     in case any optional dep still references the legacy constant
#     (cheap, idempotent, doesn't hurt if unused).
#
# The smoke test exercises every import the training script triggers,
# so any future regression fails `docker build` instead of crashing the
# 12-hour run.
#
# Tradeoff: lose Unsloth's fast kernels (~20-30% slower per step). For our
# 15-step / 12-hour run, this is fine — even with the slowdown we finish
# in ~8h on A100. The transformers + peft fallback path in train.py handles
# everything Unsloth would have done.

FROM nvidia/cuda:12.1.1-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3.11-dev python3.11-venv python3-pip git curl gcc \
    && ln -sf /usr/bin/python3.11 /usr/bin/python \
    && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --upgrade pip setuptools wheel \
    --trusted-host pypi.org --trusted-host files.pythonhosted.org

# torch first (large download — isolate it for cache hits on iterations)
RUN pip install --no-cache-dir \
    torch==2.5.1 torchvision \
    --index-url https://download.pytorch.org/whl/cu121 \
    --trusted-host download.pytorch.org

# Core training stack — modern set with GRPOTrainer.
#
# trl 0.15.x is the first widely-deployed trl with GRPOTrainer at the
# `from trl import GRPOTrainer` top-level. (I incorrectly thought 0.13
# had it; it didn't — it's only exposed via the deeper module path there.)
# 0.15 also brings the unconditional optional-integration imports
# (mergekit, llm_blender via judges.py / callbacks.py) that we have to
# cope with — see steps below.
#
# transformers 4.46.3 + peft 0.13.2 + accelerate 1.1.1 + datasets 3.1.0
# are the release-window-aligned versions trl 0.15 was tested against.
RUN pip install --no-cache-dir \
    --trusted-host pypi.org --trusted-host files.pythonhosted.org \
    "transformers==4.46.3" \
    "accelerate==1.1.1" \
    "peft==0.13.2" \
    "datasets==3.1.0" \
    "trl==0.15.2"

# 4-bit quantisation (only used when train.py runs WITHOUT --no-4bit).
RUN pip install --no-cache-dir \
    --trusted-host pypi.org --trusted-host files.pythonhosted.org \
    "bitsandbytes>=0.43"

# trl 0.15+ chain-imports `mergekit` from callbacks.py unconditionally.
# Install with full deps so the import works.
RUN pip install --no-cache-dir \
    --trusted-host pypi.org --trusted-host files.pythonhosted.org \
    "mergekit"

# Patch transformers.utils.hub.py to add the legacy `TRANSFORMERS_CACHE`
# constant. Some libs (incl. llm_blender) still reference the old name.
# Even with our llm_blender stub below, this patch is cheap insurance.
RUN HUB_PY=/usr/local/lib/python3.11/dist-packages/transformers/utils/hub.py \
 && grep -q '^TRANSFORMERS_CACHE' "$HUB_PY" \
    || printf '\n# Legacy alias for libs that haven'\''t caught up to the rename (added by Dockerfile.dgx)\nTRANSFORMERS_CACHE = HF_HUB_CACHE if "HF_HUB_CACHE" in dir() else "~/.cache/huggingface/hub"\n' >> "$HUB_PY"

# Stub out `llm_blender` instead of installing the real one.
#
# Why: trl 0.15.2's `judges.py` does `import llm_blender` unconditionally,
# but the real package on pypi has heavy runtime deps (dataclasses_json,
# sentence-transformers, pytorch-lightning, etc.) that drag in incompatible
# versions of transformers / cause cascading dep failures. Our GRPO code
# never instantiates a judge — `import llm_blender` only needs the module
# to BE IMPORTABLE.
#
# Solution: replace the package with a 1-class stub. trl's module load
# succeeds; if anything DOES try to use llm_blender.Blender at runtime,
# it raises a clear RuntimeError instead of crashing in some library
# deep in the stack. Free, robust, no dep cascade.
RUN pip uninstall -y llm-blender 2>/dev/null || true \
 && rm -rf /usr/local/lib/python3.11/dist-packages/llm_blender \
 && mkdir -p /usr/local/lib/python3.11/dist-packages/llm_blender \
 && printf '%s\n' \
    '"""Stub llm_blender — survivecity-v2-dgx does not use judge functionality."""' \
    '' \
    'class Blender:' \
    '    """Stub. The real llm_blender package conflicts with our pinned stack."""' \
    '    def __init__(self, *args, **kwargs):' \
    '        raise RuntimeError(' \
    '            "llm_blender.Blender is stubbed in survivecity-v2-dgx. "' \
    '            "Our GRPO pipeline does not use judges. If you need this, "' \
    '            "build a separate image with the full llm-blender package."' \
    '        )' \
    '    def loadranker(self, *args, **kwargs): pass' \
    '    def loadfuser(self, *args, **kwargs): pass' \
    '    def rank(self, *args, **kwargs): raise RuntimeError("llm_blender stubbed")' \
    '    def fuse(self, *args, **kwargs): raise RuntimeError("llm_blender stubbed")' \
    > /usr/local/lib/python3.11/dist-packages/llm_blender/__init__.py

# Belt-and-suspenders: ensure torchao is NOT installed. peft >=0.13's
# strict torchao version check fires pre-emptively in dispatch chains;
# safer to leave torchao absent (the check returns False cleanly).
RUN pip uninstall -y torchao || true

# Full-path import smoke test. Exercises the EXACT module load chain that
# `training/train.py` triggers at runtime, so any future regression fails
# `docker build` (15 min) instead of crashing the actual 12-hour run.
RUN python -c "\
import importlib.util; \
import torch; \
import transformers; \
import peft; \
import datasets; \
import accelerate; \
import bitsandbytes; \
import huggingface_hub; \
import trl; \
import mergekit; \
import llm_blender; \
from transformers import AutoModelForCausalLM, AutoTokenizer, BitsAndBytesConfig; \
from transformers.processing_utils import Unpack; \
from transformers.quantizers.auto import AutoHfQuantizer; \
from transformers.utils.hub import TRANSFORMERS_CACHE; \
from peft import get_peft_model, LoraConfig, prepare_model_for_kbit_training, PeftModel; \
from trl import GRPOTrainer, GRPOConfig; \
ta = importlib.util.find_spec('torchao'); \
print('torch       ', torch.__version__); \
print('transformers', transformers.__version__); \
print('peft        ', peft.__version__); \
print('datasets    ', datasets.__version__); \
print('accelerate  ', accelerate.__version__); \
print('trl         ', trl.__version__); \
print('bitsandbytes', bitsandbytes.__version__); \
print('mergekit    ', 'present'); \
print('llm_blender ', 'present (TRANSFORMERS_CACHE alias =', TRANSFORMERS_CACHE, ')'); \
print('torchao     ', 'absent (intended)' if ta is None else 'PRESENT (unexpected)'); \
assert ta is None, 'torchao should be uninstalled at build time'; \
print('FULL TRAINING IMPORT CHAIN OK')"

# Logging / plotting / hub
RUN pip install --no-cache-dir \
    --trusted-host pypi.org --trusted-host files.pythonhosted.org \
    wandb "matplotlib>=3.8" tensorboard "huggingface_hub>=0.20"

# Env runtime deps (server side; harmless even when running training-only)
RUN pip install --no-cache-dir \
    --trusted-host pypi.org --trusted-host files.pythonhosted.org \
    "pydantic>=2.0" "fastapi>=0.104" "uvicorn[standard]>=0.24"

# Source — copy after deps so iterative edits don't bust the dep cache
COPY survivecity_v2_env/ survivecity_v2_env/
COPY server/             server/
COPY training/           training/
COPY openenv.yaml        ./
COPY pyproject.toml      ./

# Runtime dirs (LoRAs, optimizer state, eval results, simulator transcripts).
# Mount these as volumes in `docker run` so they survive container restarts.
RUN mkdir -p /app/checkpoints /app/eval_results /app/results

EXPOSE 7861

# Default CMD launches a 15-step training run with all the v2 defaults,
# fitting comfortably in a 12-hour DGX session.
#
#   --max-steps 15                     15 steps total
#   --save-steps 1                     checkpoint every step → 15 saves
#   --save-total-limit 15              keep all 15 on disk + Hub
#   --num-generations 12               bigger group → stronger GRPO gradient
#   --grad-accum-steps 4               48 generations evaluated per update
#   --max-completion-length 512        more tokens per response
#   --no-4bit                          bf16 base (cleaner grads than nf4)
#   --gradient-checkpointing (default) lets the bigger group fit
#   --vram-reserve-gb 16 (default)     holder pins remaining VRAM so
#                                       co-tenants on shared DGX can't
#                                       claim it mid-run. Set 0 if you
#                                       own the GPU exclusively.
#
# To enable Hub push, override CMD or pass extra args:
#   docker run ... survivecity-v2-dgx <override-args>
# and set HUGGINGFACE_TOKEN with `-e HUGGINGFACE_TOKEN=...`.
CMD ["bash", "-c", "\
echo '=== SurviveCity v2 DGX training (15 steps, save every step) ===' && \
echo 'GPU info:' && \
nvidia-smi -L || true && \
python -m training.train \
    --model-name Qwen/Qwen2.5-3B-Instruct \
    --max-steps 15 \
    --save-steps 1 \
    --save-total-limit 15 \
    --output-dir /app/checkpoints \
    --num-generations 12 \
    --grad-accum-steps 4 \
    --max-completion-length 512 \
    --lora-r 32 \
    --lora-alpha 64 \
    --max-seq-length 4096 \
    --no-4bit \
    --report-to tensorboard \
"]
