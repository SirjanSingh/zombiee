# SurviveCity v2 — DGX training container.
#
# Mirrors v1/Dockerfile.dgx (the known-good stack we used on DGX in April 2026)
# with v2 paths and port 7861. The pin set below was chosen because:
#
#   * torch==2.5.1 (cu121)              — last torch that bundles the inductor
#                                         submodule unsloth_zoo's import chain
#                                         requires, AND has cuDNN built-ins
#                                         supporting Ampere/Hopper bf16 fast paths.
#   * transformers==4.40.2              — TRL 0.8.6 was tested against this minor.
#   * peft==0.10.0                      — adapter file layout matches what v1's
#                                         eval cells expect.
#   * trl==0.8.6                        — GRPOTrainer API stable here; >=0.15
#                                         needs the warnings_issued shim.
#   * datasets==2.19.1, accelerate==0.30.1
#   * bitsandbytes>=0.41                — 4-bit nf4 path (only needed if you DON'T
#                                         pass --no-4bit to training/train.py).
#   * unsloth[cu121-torch250] (git)     — fast kernels (Ampere+ only — A100/H100).
#                                         Skip with UNSLOTH_DISABLE=1 to use the
#                                         transformers+peft fallback in train.py.
#   * torchao==0.7.0  ★ CRITICAL PIN ★  — newer torchao (>=0.8) references
#                                         torch.int1 (only present in torch 2.6+).
#                                         transformers/quantizers/auto.py imports
#                                         torchao eagerly, so without this pin the
#                                         very first `import transformers` raises
#                                         AttributeError. We force-reinstall after
#                                         transformers to override whatever pip
#                                         resolved earlier.
#
# This image runs TRAINING by default (uses the local v2 SurviveCityV2Env in
# the GRPO reward function — no HTTP server required during training). The
# server side of v2 lives in the slim Dockerfile and is only needed for OpenEnv
# submission / external evaluation.

FROM nvidia/cuda:12.1.1-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3.11-dev python3.11-venv python3-pip git curl gcc \
    && ln -sf /usr/bin/python3.11 /usr/bin/python \
    && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --upgrade pip setuptools wheel \
    --trusted-host pypi.org --trusted-host files.pythonhosted.org

# torch first (large download, isolate the failure point)
RUN pip install --no-cache-dir \
    torch==2.5.1 torchvision \
    --index-url https://download.pytorch.org/whl/cu121 \
    --trusted-host download.pytorch.org

# Core training stack — exact pins from the v1 DGX run that worked
RUN pip install --no-cache-dir \
    --trusted-host pypi.org --trusted-host files.pythonhosted.org \
    "transformers==4.40.2" \
    "accelerate==0.30.1" \
    "peft==0.10.0" \
    "datasets==2.19.1" \
    "trl==0.8.6"

RUN pip install --no-cache-dir \
    --trusted-host pypi.org --trusted-host files.pythonhosted.org \
    "bitsandbytes>=0.41"

RUN pip install --no-cache-dir \
    --trusted-host pypi.org --trusted-host files.pythonhosted.org \
    "unsloth[cu121-torch250] @ git+https://github.com/unslothai/unsloth.git"

# TRL 0.15+ has a cascade of "optional" integrations that are imported
# unconditionally in the GRPOTrainer load path. Each one takes a moment to
# discover via the smoke test (lines further down). Known list as of
# 2026-04-25 — install all of them so `from trl import GRPOTrainer` works:
#
#   trl/trainer/grpo_trainer.py
#       -> callbacks.py
#           -> mergekit_utils.py     -> import mergekit
#           -> judges.py             -> import llm_blender
#
# We don't actually use merge OR judge functionality; these are dead-weight
# imports for our code path. But TRL doesn't gate them, so we have to ship
# them. (Alternative: pin trl to <=0.13.x, but that risks breaking the
# Unsloth-installed transformers/peft compat. Easier to just install.)
RUN pip install --no-cache-dir \
    --trusted-host pypi.org --trusted-host files.pythonhosted.org \
    "mergekit" \
    "llm-blender"

# torchao gymnastics, take 2:
#
#   * Newer torchao (>=0.8) references `torch.int1` which only exists in
#     torch 2.6+. transformers/quantizers/auto.py imports torchao eagerly, so
#     a torchao install on torch 2.5 raises AttributeError at module load.
#   * The "obvious" fix — pinning torchao==0.7.0 — works for `import transformers`
#     but trips peft >=0.13's `is_torchao_available()` strict check, which DEMANDS
#     torchao >= 0.16.0. peft fires this check pre-emptively in every LoRA
#     dispatcher chain even when no torchao layers are present in the model.
#   * We don't actually USE torchao quantisation (we train in bf16). So the
#     correct move is to UNINSTALL torchao entirely. transformers' eager import
#     is wrapped in try/except ImportError; an absent torchao module returns
#     None and everything downstream falls back to the standard path. peft's
#     is_torchao_available() returns False cleanly (no exception), and
#     dispatch_torchao gets skipped in favour of the Linear dispatcher for
#     q,k,v,o_proj — which is what we want.
RUN pip uninstall -y torchao || true

# Full-path sanity check: simulate the EXACT imports `training/train.py` uses,
# so any future transitive-dep regression fails `docker build` instead of
# crashing the actual 12-hour training run. We skip `import unsloth` (its
# CUDA probe needs a GPU which docker build doesn't have) but exercise every
# OTHER module the training script touches.
RUN python -c "\
import importlib.util; \
import torch; \
import transformers; \
import peft; \
import datasets; \
import accelerate; \
import bitsandbytes; \
import huggingface_hub; \
from transformers import AutoModelForCausalLM, AutoTokenizer, BitsAndBytesConfig; \
from transformers.processing_utils import Unpack; \
from transformers.quantizers.auto import AutoHfQuantizer; \
from peft import get_peft_model, LoraConfig, prepare_model_for_kbit_training, PeftModel; \
from trl import GRPOTrainer, GRPOConfig; \
ta = importlib.util.find_spec('torchao'); \
mk = importlib.util.find_spec('mergekit'); \
lb = importlib.util.find_spec('llm_blender'); \
print('torch       ', torch.__version__); \
print('transformers', transformers.__version__); \
print('peft        ', peft.__version__); \
print('datasets    ', datasets.__version__); \
print('accelerate  ', accelerate.__version__); \
import trl; print('trl         ', trl.__version__); \
print('bitsandbytes', bitsandbytes.__version__); \
print('torchao     ', 'absent (intended)' if ta is None else 'PRESENT (unexpected)'); \
print('mergekit    ', 'present' if mk is not None else 'ABSENT (would break trl)'); \
print('llm_blender ', 'present' if lb is not None else 'ABSENT (would break trl judges)'); \
assert ta is None, 'torchao should be uninstalled at build time'; \
assert mk is not None, 'mergekit must be installed for trl GRPO imports'; \
assert lb is not None, 'llm_blender must be installed for trl GRPO imports (judges chain)'; \
print('FULL TRAINING IMPORT CHAIN OK')"

# Logging / plotting / hub
RUN pip install --no-cache-dir \
    --trusted-host pypi.org --trusted-host files.pythonhosted.org \
    wandb "matplotlib>=3.8" tensorboard "huggingface_hub>=0.20"

# Env runtime deps (server side; harmless even when running training-only)
RUN pip install --no-cache-dir \
    --trusted-host pypi.org --trusted-host files.pythonhosted.org \
    "pydantic>=2.0" "fastapi>=0.104" "uvicorn[standard]>=0.24"

# Source — copy after deps so iterative edits don't bust the dep cache
COPY survivecity_v2_env/ survivecity_v2_env/
COPY server/             server/
COPY training/           training/
COPY openenv.yaml        ./
COPY pyproject.toml      ./

# Local checkpoint dir (trained LoRAs, optimizer state); mount this as a
# volume in `docker run` so checkpoints survive container restarts.
RUN mkdir -p /app/checkpoints /app/eval_results /app/results

EXPOSE 7861

# Default CMD: run training. Override at `docker run` time for one-off eval /
# server / simulator launches. The training script uses the local v2
# SurviveCityV2Env in its GRPO reward function — no in-container HTTP needed.
#
# DGX defaults (30 GB VRAM Ampere/Hopper) — saturate the GPU for GRPO,
# fit in a 12-hour session, save every step:
#   --max-steps 15                     15 steps total (~6h on A100, ~12h on V100)
#   --save-steps 1                     checkpoint after every single step (15 saves)
#   --save-total-limit 15              keep all 15 on disk + Hub (~450 MB)
#   --num-generations 12               bigger group → stronger GRPO gradient
#   --grad-accum-steps 4               48 generations evaluated per gradient update
#   --max-completion-length 512        more tokens per response
#   --no-4bit                          bf16 base (cleaner grads than 4-bit nf4)
#   --gradient-checkpointing (default) lets the bigger group fit
#   --optim adamw_torch_fused          ~3-5% throughput gain on sm_80+
#   --vram-reserve-gb 16 (default)     holder pins remaining VRAM so co-tenants
#                                       on shared DGX can't claim it mid-run.
#                                       Set 0 if you own the GPU exclusively.
#
# To enable Hub push, override CMD or pass extra args:
#   docker run ... survivecity-v2-dgx <override-args>
# and set HUGGINGFACE_TOKEN with `-e HUGGINGFACE_TOKEN=...`.
CMD ["bash", "-c", "\
echo '=== SurviveCity v2 DGX training (15 steps, save every step) ===' && \
echo \"GPU info:\" && \
nvidia-smi -L || true && \
python -m training.train \
    --model-name Qwen/Qwen2.5-3B-Instruct \
    --max-steps 15 \
    --save-steps 1 \
    --save-total-limit 15 \
    --output-dir /app/checkpoints \
    --num-generations 12 \
    --grad-accum-steps 4 \
    --max-completion-length 512 \
    --lora-r 32 \
    --lora-alpha 64 \
    --max-seq-length 4096 \
    --no-4bit \
    --report-to tensorboard \
"]
